Generated by gemini-2.5-flash with PredictableKeys

[style]
layout=A4
unit=inch
orientation=portrait
font-family="Times New Roman"
font-size=12
color=#000000
line-height=1.5
m=1

[title]
title=Invoice

[header]
left={{title}}
right={{date}}
font-size=10
color=#666666

[footer]
center=Page {{page}} of {{total}}
font-size=9
color=#666666

[section 0]
name=invoice_document
var=info, items, summary
keys=info.invoice_no, info.date, info.customer, items.name, items.qty, items.price, summary.total
formats=[info.date:yyyy-MM-dd], [items.price:#,##0], [summary.total:#,##0]

--- BODY ---
<p><b>INVOICE</b></p>
<p><b>Invoice No:</b> {{info.invoice_no}}</p>
<p><b>Date:</b> {{info.date}}</p>
<p><b>Customer:</b> {{info.customer}}</p>
<br>
<table border=1 width=100%>
  <row bg=#f0f0f0>
    <col width=50%><b>Item</b></col>
    <col width=15% align=center><b>Qty</b></col>
    <col width=35% align=right><b>Price</b></col>
  </row>
  <loop:row x from items>
    <col>{{x.name}}</col>
    <col align=center>{{x.qty}}</col>
    <col align=right>{{x.price}}</col>
  </loop:row>
</table>
<br>
<p align=right><b>Total:</b> {{summary.total}}</p>

[object-unpredictable]
[keys-unpredictable]
